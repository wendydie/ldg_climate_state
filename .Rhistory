compute_richness_summary(
dat = dat,
xy = c("paleolat2", "paleolng2"), # Assuming these columns represent coordinates
iter = 1,
nSite = 40,
r = 1500,
crs = 'epsg:4326',
q = c(0),
datatype = "incidence_freq",
